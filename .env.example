# Copy to .env and fill in to enable optional features.

# VirusTotal API key (https://www.virustotal.com/gui/my-apikey).
# When set, FileDessect queries VirusTotal for the file's hash reputation.
# When empty, FileDessect still provides a VirusTotal permalink per file.
VT_API_KEY=

# Maximum upload size in megabytes.
MAX_UPLOAD_MB=100

# --- Interactive disassembly (Cutter/Rizin engine) -------------------------
# When true, an analysed native binary (PE/ELF/Mach-O) is retained in an
# isolated session directory for a short TTL so the UI can drive the Rizin
# engine on demand — disassembling or decompiling any function live, a
# "Cutter in the browser" experience. Requires the `rizin` binary.
# OFF by default: it temporarily retains a (potentially malicious) sample,
# which the default privacy stance avoids. The deep one-shot analysis on the
# report page works regardless of this flag.
INTERACTIVE_DISASM=false

# How long a retained interactive session lives before it is purged (seconds).
SESSION_TTL_SECONDS=1200

# Samples larger than this (MB) are never retained for interactive sessions.
MAX_INTERACTIVE_MB=50
