# Copy to .env and fill in to enable optional features.

# VirusTotal API key (https://www.virustotal.com/gui/my-apikey).
# When set, FileDessect queries VirusTotal for the file's hash reputation.
# When empty, FileDessect still provides a VirusTotal permalink per file.
VT_API_KEY=

# Maximum upload size in megabytes.
MAX_UPLOAD_MB=100
